---
import { SITE } from "~/config";
import { getCanonical, getHomePermalink } from "~/utils/permalinks";
import Layout from "~/layouts/HomePageLayout.astro";
import CurriculumSection from "~/components/curriculum/index.astro";
import BentoGridLayout from "~/layouts/BentoGridLayout.astro";
import BentoCell from "~/layouts/BentoCell.astro";
import HeroStatus from "~/components/widgets/HeroStatus.astro";
import BlogSection from "~/components/blog/index.astro";
import HeroSection from "~/components/hero/index.astro";
import Footer from "~/components/ui/Footer.astro";

const meta = {
  title: SITE.title,
  description: SITE.description,
  canonical: getCanonical(getHomePermalink()),
};
---

<Layout {meta}>
  <BentoGridLayout>
    <BentoCell span={10}>
      <HeroStatus />
    </BentoCell>

    <HeroSection />

    <CurriculumSection />

    <BlogSection />
    <Footer />
  </BentoGridLayout>
</Layout>
