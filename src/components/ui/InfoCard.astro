---
// src/components/InfoCard.astro

import type { HTMLAttributes } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";
import { cn } from "~/utils/cn";

const infoCardTerm = cva("m-0 text-sm font-black uppercase leading-tight", {
  variants: {
    intent: {
      loud: "text-loud",
      brutal: "text-brutal",
      acid: "text-acid",
      neon: "text-neon",
      signal: "text-signal",
      technical: "text-technical",
    },
  },
  defaultVariants: {
    intent: "loud",
  },
});

export interface InfoCardItem {
  term: string;
  description: string;
}

export interface Props
  extends VariantProps<typeof infoCardTerm>, HTMLAttributes<"aside"> {
  title: string;
  ariaLabel: string;
  items: InfoCardItem[];
  hasBadge?: boolean;
}

const {
  title,
  ariaLabel,
  intent = "loud",
  class: className = "",
  items,
  hasBadge = false,
  ...rest
} = Astro.props;
---

<aside
  class={cn(
    "h-full border-[3px] border-contrast bg-contrast-dark p-4 shadow-contrast dark:border-contrast dark:bg-contrast dark:shadow-contrast-shadow",
    className,
  )}
  aria-label={ariaLabel}
  {...rest}
>
  <p class="mb-3 text-xs leading-tight font-black uppercase">{title}</p>

  <dl class="m-0">
    {
      items.map((item) => (
        <div class="grid grid-cols-[5.5rem_minmax(0,1fr)] gap-3 border-t-2 border-black py-3 max-[46rem]:grid-cols-1 max-[46rem]:gap-1 dark:border-yellow-50">
          <dt class={infoCardTerm({ intent })}>{item.term}</dt>
          <dd class="m-0 text-sm leading-tight font-black uppercase">
            {item.description}
          </dd>
        </div>
      ))
    }
  </dl>

  {
    hasBadge && (
      <div class="mt-3 inline-block border-[3px] border-black bg-black px-3 py-2 text-sm leading-tight font-black text-white uppercase dark:bg-white dark:text-black">
        <slot name="badge" />
      </div>
    )
  }
</aside>
