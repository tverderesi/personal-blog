---
import { Icon } from 'astro-icon/components';

type DownloadLink = {
	href: string;
	filename: string;
	format: string;
	icon: string;
	ariaLabel: string;
};

const linkClass =
	'inline-flex items-center gap-2 border-2 border-black bg-stone-100 px-3 py-2 text-sm font-black uppercase text-black shadow-[4px_4px_0_#050505] transition-transform duration-100 hover:-translate-y-0.5 hover:bg-red-500 hover:text-white focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-red-500 dark:border-yellow-300 dark:bg-black dark:text-yellow-50 dark:shadow-[4px_4px_0_#ff3b30] dark:hover:bg-red-500';
const { downloadLinks } = Astro.props as { downloadLinks: DownloadLink[] };
---

<section
	aria-labelledby="download-curriculum"
	class="border-4 border-black bg-stone-100 p-5 text-black shadow-[8px_8px_0_#050505] dark:border-yellow-300 dark:bg-black dark:text-yellow-50 dark:shadow-[8px_8px_0_#ff3b30]"
>
	<h2 id="download-curriculum" class="text-lg font-black uppercase">Download this curriculum</h2>
	<div class="mt-4 flex flex-col gap-3 sm:flex-row">
		{
			downloadLinks.map((link) => (
				<a href={link.href} download={link.filename} class={linkClass} aria-label={link.ariaLabel}>
					<Icon name={link.icon} class="h-5 w-5" aria-hidden="true" /> {link.format}
				</a>
			))
		}
	</div>
</section>
