---
import { SITE } from "~/config";

const base = `${SITE.basePathname}${SITE.basePathname.endsWith("/") ? "" : "/"}`;
---

<link
  id="site-favicon"
  rel="icon"
  type="image/svg+xml"
  href={`${base}favicon-light.svg?v=8`}
/>

<script is:inline define:vars={{ base }}>
  const favicon = document.querySelector("#site-favicon");
  const darkModeQuery = window.matchMedia("(prefers-color-scheme: dark)");

  function updateFavicon() {
    if (!favicon) return;

    favicon.setAttribute(
      "href",
      darkModeQuery.matches
        ? `${base}favicon-dark.svg?v=8`
        : `${base}favicon-light.svg?v=8`,
    );
  }

  updateFavicon();
  darkModeQuery.addEventListener?.("change", updateFavicon);
</script>

<meta
  name="theme-color"
  content="#f7f3ea"
  media="(prefers-color-scheme: light)"
/>
<meta
  name="theme-color"
  content="#111111"
  media="(prefers-color-scheme: dark)"
/>

<meta name="msapplication-TileColor" content="#1a1a1a" />
<meta
  name="msapplication-TileImage"
  content={`${base}android-chrome-512x512.png`}
/>

<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Tverderesi.dev" />

<meta name="application-name" content="Tverderesi.dev" />

<meta name="msapplication-config" content={`${base}browserconfig.xml`} />
<meta name="msapplication-navbutton-color" content="#1a1a1a" />
<meta name="msapplication-starturl" content="/" />
<meta name="msapplication-tooltip" content="Tverderesi.dev" />
<meta
  name="msapplication-task"
  content="name=Tverderesi.dev;action-uri=/;icon-uri=/android-chrome-512x512.png"
/>

<meta name="twitter:card" content="summary_large_image" />
<meta
  name="twitter:title"
  content="Tverderesi.dev - Fullstack Software Engineer"
/>
<meta
  name="twitter:description"
  content="My personal page with my portfolio, curriculum and personal blog."
/>
<meta name="twitter:image" content={`${base}android-chrome-512x512.png`} />
