---
import { Picture as AstroPicture } from 'astro:assets';

const {
	src,
	alt,
	sizes,
	widths,
	formats = ['avif', 'webp'],
	loading = 'lazy',
	decoding = 'async',
	class: className = '',
	...attrs
} = Astro.props;
---

{
	src && (
		<AstroPicture
			{src}
			{widths}
			{sizes}
			{formats}
			{loading}
			{decoding}
			alt={alt || ''}
			class={className}
			{...attrs}
		/>
	)
}
