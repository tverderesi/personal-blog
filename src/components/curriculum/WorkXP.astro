---
import { Icon } from "astro-icon/components";
import { workExperience } from "~/assets/curriculum";

type SelectedProject = {
  title: string;
  description: string;
};

type WorkExperience = {
  title: string;
  company: string;
  period: string;
  location: string;
  area: string;
  summary: string;
  highlights: string[];
  selectedProjects?: SelectedProject[];
  tech: string[];
};

---

{
  workExperience.map((work, index) => (
    <>
      {index > 0 ? (
        <hr class="border-primary-500 dark:border-secondary-500 mt-4 border-b-2 lg:mt-16" />
      ) : (
        ""
      )}
      <article
        class={`pt-4 lg:${index === 0 ? "pt-16" : "pt-12"} px-0 lg:px-4 mb-0`}
      >
        <div class="flex flex-col gap-2 px-0 py-5 lg:p-5 lg:pb-0">
          <div class="flex flex-col gap-2 lg:flex-row lg:items-center">
            <h3 class="flex flex-row items-start text-base font-semibold text-slate-900 lg:items-center lg:text-2xl dark:text-slate-100">
              <Icon
                name="mdi:briefcase"
                class="text-primary-500 dark:text-secondary-500 mr-1 h-6 w-6"
              />
              {work.title}
            </h3>
            <h4 class="flex flex-row font-semibold text-slate-900 dark:text-slate-100">
              <Icon
                name="mdi:office-building"
                class="text-primary-500 dark:text-secondary-500 mr-1 h-6 w-6"
              />
              {work.company}
            </h4>
          </div>

          <div class="flex w-full flex-col gap-2 py-5 font-medium lg:flex-row lg:justify-between lg:p-0">
            <p class="flex flex-row font-semibold text-slate-900 dark:text-slate-100">
              <Icon
                name="mdi:calendar"
                class="text-primary-500 dark:text-secondary-500 mr-1 h-6 w-6"
              />
              <span class="hidden lg:inline">Period</span>
              <span class="ml-1 font-semibold lg:font-light">
                {work.period}
              </span>
            </p>

            <p class="flex flex-row font-semibold text-slate-900 dark:text-slate-100">
              <Icon
                name="mdi:map"
                class="text-primary-500 dark:text-secondary-500 mr-1 h-6 w-6"
              />
              <span class="hidden lg:inline">Location</span>
              <span class="ml-1 font-semibold lg:font-light">
                {work.location}
              </span>
            </p>
          </div>

          <p class="flex flex-row font-semibold text-slate-900 dark:text-slate-100">
            <Icon
              name="mdi:laptop"
              class="text-primary-500 dark:text-secondary-500 mr-1 h-6 w-6 shrink-0"
            />
            <span class="hidden lg:inline">Area</span>
            <span class="ml-1 font-semibold lg:font-light">{work.area}</span>
          </p>

          <p class="mt-4 text-justify text-slate-900 dark:text-slate-100">
            {work.summary}
          </p>

          <div class="mt-5">
            <h5 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
              Highlights
            </h5>
            <ul class="mt-2 list-inside list-disc text-slate-900 dark:text-slate-100">
              {work.highlights.map((highlight) => (
                <li class="mb-2 text-justify">{highlight}</li>
              ))}
            </ul>
          </div>

          {work.selectedProjects && work.selectedProjects.length > 0 ? (
            <div class="mt-5">
              <h5 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                Selected Projects
              </h5>
              <div class="mt-3 grid gap-3 lg:grid-cols-2">
                {work.selectedProjects.map((project) => (
                  <article class="rounded-md border border-slate-300 p-4 dark:border-slate-700">
                    <h6 class="font-semibold text-slate-900 dark:text-slate-100">
                      {project.title}
                    </h6>
                    <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">
                      {project.description}
                    </p>
                  </article>
                ))}
              </div>
            </div>
          ) : null}

          <div class="mt-5">
            <h5 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
              Technologies
            </h5>
            <ul class="mt-3 flex flex-wrap gap-2">
              {work.tech.map((item) => (
                <li class="rounded-md bg-slate-200 px-3 py-2 text-sm font-semibold text-slate-900 dark:bg-slate-800 dark:text-slate-100">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </article>
    </>
  ))
}
