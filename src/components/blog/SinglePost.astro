---
import Picture from '~/components/core/Picture.astro';
import PostTags from '~/components/atoms/Tags.astro';
import SocialShare from '~/components/atoms/SocialShare.astro';

import { getFormattedDate } from '~/utils/utils';

const { post, url } = Astro.props;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
	<article>
		<header class={post.image ? 'text-center' : ''}>
			<p class="mx-auto mb-4 max-w-max border-2 border-black bg-yellow-300 px-4 py-2 font-black uppercase text-black dark:border-yellow-300 dark:bg-black dark:text-yellow-50 sm:px-6 lg:max-w-4xl">
				<time datetime={post.publishDate}>{getFormattedDate(post.publishDate)}</time> ~ {Math.ceil(post.readingTime)} min
				read
			</p>
			<h1
				class="mx-auto mb-8 max-w-3xl border-4 border-black bg-stone-100 px-4 py-3 font-heading text-4xl font-black uppercase leading-none text-black shadow-[10px_10px_0_#050505] dark:border-yellow-300 dark:bg-black dark:text-yellow-50 dark:shadow-[10px_10px_0_#ff3b30] sm:px-6 md:text-5xl lg:max-w-4xl"
			>
				{post.title}
			</h1>
			<p class="mx-auto max-w-3xl border-2 border-black bg-white px-4 py-4 font-bold text-black dark:border-yellow-300 dark:bg-black dark:text-yellow-50 sm:px-6 lg:max-w-4xl">
				{post.description}
			</p>
			{
				post.image ? (
					<Picture
						src={post.image}
						class="max-w-full border-y-4 border-black grayscale contrast-125 lg:max-w-6xl mx-auto mt-4 mb-6 bg-yellow-300 dark:border-yellow-300 dark:bg-black"
						widths={[400, 900]}
						sizes="(max-width: 900px) 400px, 900px"
						alt={post.description}
						aspectRatio="16:9"
					/>
				) : (
					<div class="max-w-3xl lg:max-w-4xl mx-auto px-4 sm:px-6">
						<div class="border-t dark:border-slate-700" />
					</div>
				)
			}
		</header>
		<div
			class="container brutalist-panel mx-auto mt-8 max-w-3xl px-6 py-6 text-justify prose prose-lg prose-md prose-headings:font-heading prose-headings:font-black prose-headings:uppercase prose-a:text-red-600 prose-a:font-black prose-img:border-4 prose-img:border-black dark:prose-invert dark:prose-headings:text-yellow-50 dark:prose-a:text-yellow-300 sm:px-6 lg:max-w-4xl lg:prose-xl"
		>
			{post.Content ? <post.Content /> : <Fragment set:html={post.body} />}
		</div>
		<div class="container mx-auto px-6 sm:px-6 max-w-3xl lg:max-w-4xl mt-8 flex justify-between flex-col sm:flex-row">
			<PostTags tags={post.tags} class="mr-5" />
			<SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-400 dark:text-slate-600" />
		</div>
	</article>
</section>
