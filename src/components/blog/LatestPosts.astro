---
import { findLatestPosts } from "~/utils/posts";
import BentoCell from "~/layouts/BentoCell.astro";
import LastestArticleCard, {
  type Props as LastestArticleCardProps,
} from "../ui/LastestArticleCard.astro";

const count = 4;
const posts = await findLatestPosts({ count });
---

{
  posts.map(({ title, slug }: LastestArticleCardProps) => (
    <BentoCell
      span={Math.floor(12 / count) as 1 | 2 | 3 | 4 | 6 | 12}
      class="h-full"
    >
      <LastestArticleCard title={title} slug={slug} />
    </BentoCell>
  ))
}
