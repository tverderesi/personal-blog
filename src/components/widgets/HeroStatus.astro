<aside
  class="border-[3px] border-black bg-gray-100 text-[clamp(0.72rem,1.7vw,0.88rem)] font-black uppercase leading-none shadow-[8px_8px_0_#000] dark:border-yellow-50 dark:bg-[#111] dark:shadow-[8px_8px_0_var(--color-loud-shadow-dark)]"
  aria-labelledby="hero-status-title"
>
  <h2 id="hero-status-title" class="sr-only">Site status metadata</h2>

  <dl class="flex flex-wrap">
    <div
      class="border-r-[3px] border-black dark:border-yellow-50 max-[46rem]:w-full max-[46rem]:border-r-0 max-[46rem]:border-b-[3px]"
    >
      <dt class="sr-only">Status</dt>
      <dd class="m-0 px-3 py-3">STATUS: SHIPPING</dd>
    </div>

    <div
      class="border-r-[3px] border-black dark:border-yellow-50 max-[46rem]:w-full max-[46rem]:border-r-0 max-[46rem]:border-b-[3px]"
    >
      <dt class="sr-only">Mode</dt>
      <dd class="m-0 px-3 py-3">MODE: SHARP / WEIRD / TECHNICAL</dd>
    </div>

    <div class="bg-loud text-black max-[46rem]:w-full grow">
      <dt class="sr-only">Focus</dt>
      <dd class="m-0 px-3 py-3">
        FOCUS: LEGACY SYSTEMS / PRODUCT TOOLS / AI INTERFACES
      </dd>
    </div>
  </dl>
</aside>
