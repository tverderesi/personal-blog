---
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';
import Logo from '../atoms/Logo.astro';
---

<footer class="border-t-4 border-black bg-yellow-300 p-10 text-black dark:border-yellow-300 dark:bg-black dark:text-yellow-50">
	<div class="flex flex-col lg:flex-row justify-center items-center">
		<a class="inline-block font-bold text-xl" href={getHomePermalink()}><Logo /></a>
		<ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0">
			<li>
				<a
					class="brutalist-link text-sm p-2.5 inline-flex items-center"
					aria-label="Twitter"
					href="https://twitter.com/tverderesi_dev"
					target="_blank"
					referrerpolicy="no-referrer"
				>
					<Icon name="tabler:brand-twitter" class="w-5 h-5" />
				</a>
			</li>

			<li>
				<a
					class="brutalist-link text-sm p-2.5 inline-flex items-center"
					aria-label="Github"
					href="https://github.com/tverderesi"
					target="_blank"
					referrerpolicy="no-referrer"
				>
					<Icon name="tabler:brand-github" class="w-5 h-5" />
				</a>
			</li>
			<li>
				<a
					class="brutalist-link text-sm p-2.5 inline-flex items-center"
					aria-label="email"
					href="mailto:tverderesi@gmail.com"
					target="_blank"
					referrerpolicy="no-referrer"
				>
					<Icon name="tabler:mail" class="w-5 h-5" />
				</a>
			</li>
		</ul>
	</div>
	<div class="text-sm text-center pt-3 w-full flex flex-row flex-wrap items-center justify-center">
		Schedule Calendly meeting
		<ul class="inline-flex gap-3 ml-3">
			<li>
				<a class="text-black underline hover:bg-red-500 hover:text-white dark:text-yellow-50 inline font-black" href="https://calendly.com/tverderesi/30min">
					<Icon name="tabler:clock" class="w-4 h-4 inline-flex self-center align-text-top mr-1" />30 minutes</a
				>
			</li>
			<li>
				<a class="text-black underline hover:bg-red-500 hover:text-white dark:text-yellow-50 inline font-black" href="https://calendly.com/tverderesi/1hr-meeting">
					<Icon name="tabler:clock" class="w-4 h-4 inline-flex self-center align-text-top mr-1" />1 hour</a
				>
			</li>
		</ul>
	</div>

	<div class="text-sm text-black mr-4 dark:text-yellow-50 pt-3 text-center w-full">
		<a class="text-black underline hover:bg-red-500 hover:text-white dark:text-yellow-50" aria-label="Github" href="https://github.com/onwidget/astrowind"> Astrowind</a> Template
		by
		<a class="text-black underline hover:bg-red-500 hover:text-white dark:text-yellow-50" href="https://onwidget.com/"> onWidget</a> · All rights reserved.
	</div>
</footer>
