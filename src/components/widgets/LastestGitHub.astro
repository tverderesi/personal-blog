---
const githubUrl = 'https://github.com/tverderesi';
---

<section class="flex flex-col items-center justify-center border-b-4 border-black bg-stone-100 px-6 py-12 text-center dark:border-yellow-300 dark:bg-black">
	<h5 class="font-heading text-4xl font-black uppercase text-black dark:text-yellow-50 sm:leading-none">GitHub</h5>
	<p class="mt-4 max-w-xl border-2 border-black bg-white px-4 py-3 font-bold text-black dark:border-yellow-300 dark:bg-black dark:text-yellow-50">
		See my repositories and current experiments on GitHub.
	</p>
	<a
		href={githubUrl}
		class="brutalist-link mt-6 inline-flex items-center justify-center px-5 py-3 font-black uppercase transition"
	>
		View GitHub Profile
	</a>
</section>
