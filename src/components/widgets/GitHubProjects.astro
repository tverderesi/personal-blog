---
const githubUrl = 'https://github.com/tverderesi';
---

<section class="mx-auto w-3/4 py-10 text-center">
	<h2 class="text-3xl font-semibold text-slate-900 dark:text-slate-100">GitHub</h2>
	<p class="mx-auto mt-4 max-w-xl text-slate-700 dark:text-slate-300">
		Explore my open-source work, experiments, and recent projects on GitHub.
	</p>
	<a
		href={githubUrl}
		class="mt-6 inline-flex items-center justify-center rounded-md bg-primary-500 px-5 py-3 font-semibold text-white shadow-lg shadow-gray-300 transition hover:bg-primary-600 dark:bg-secondary-500 dark:shadow-black/30 dark:hover:bg-secondary-600"
	>
		View GitHub Profile
	</a>
</section>
