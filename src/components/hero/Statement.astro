---
import Card from "~/components/ui/Card.astro";
---

<Card
  intent="brutal"
  size="xl"
  class="h-full p-[clamp(1rem,4vw,2rem)] text-black"
  aria-label="Hero statement"
>
  <p
    class="m-0 px-[clamp(0.5rem,2vw,2rem)] py-1 text-justify text-[clamp(1.45rem,4.4vw,3.1rem)] leading-[1.02] font-black tracking-tighter"
  >
    I turn haunted systems, product tools, and AI interfaces into things humans
    can actually use and enjoy.
  </p>
</Card>
