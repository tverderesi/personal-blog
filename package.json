    "@astrojs/tailwind": "^5.1.5",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource/inter": "^4.5.15",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/brandico": "^1.2.3",
